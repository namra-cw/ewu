  "license": "UNLICENSED",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "prepare": "husky",
    "start:api": "node scripts/serve.mjs api",
    "start:email-sync": "node scripts/serve.mjs email-sync",
    "start:email-classifier": "node scripts/serve.mjs email-classifier",
    "start:queue-worker": "node scripts/serve.mjs queue-worker",
    "start:all": "nx run-many --target=serve --projects=api,email-sync,email-classifier,queue-worker --parallel=4",
    "build:all": "nx run-many --target=build --all",
    "test:all": "nx run-many --target=test --all",
    "lint:all": "nx run-many --target=lint --all",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "dep-graph": "nx graph",
    "postinstall": "prisma generate --schema libs/database/prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema libs/database/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema libs/database/prisma/schema.prisma && tsx libs/database/prisma/scripts/fix-serial-to-identity.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --schema libs/database/prisma/schema.prisma",
    "prisma:studio": "prisma studio",
    "prisma:db:push": "prisma db push --schema libs/database/prisma/schema.prisma",
    "db:seed": "nx run-many --target=build --projects=@mediastar/core,@mediastar/database && node --require @swc-node/register libs/database/prisma/seed-cli.ts",
    "clean": "node scripts/clean.mjs"
  },
  "private": true,
