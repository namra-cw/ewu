{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "types": ["node"],
    "target": "es2021",
    "strictNullChecks": true,
    "noImplicitAny": true
  },
  "include": [
    "prisma/seed.ts",
    "prisma/seed-cli.ts",
    "prisma/scripts/**/*.ts",
    "src/lib/generated/**/*.ts"
