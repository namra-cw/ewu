# Application
# NODE_ENV=staging triggers HTTPS/COOKIE_DOMAIN/REDIS_PASSWORD validation.
# For local dev pointing at the staging DB, keep this as development.
NODE_ENV=development
PORT=3000
APP_NAME=ewu-media-backend
LOG_LEVEL=log

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ewu-media
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT_MS=10000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=5000
DATABASE_TX_MAX_WAIT_MS=2000
DATABASE_TX_TIMEOUT_MS=5000

# JWT / Auth (secrets must be ≥64 characters — use `openssl rand -hex 32` to generate)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Two-Factor Authentication (use `openssl rand -hex 32` to generate keys)
TWO_FACTOR_SECRET=
SESSION_MGMT_SECRET=
TOTP_ENCRYPTION_KEY=
TWO_FACTOR_MAX_ATTEMPTS=5
TWO_FACTOR_LOCKOUT_MS=900000
TWO_FACTOR_TOKEN_EXPIRY=5m
TWO_FACTOR_TRUSTED_DEVICE_TTL_MS=2592000000
TWO_FACTOR_BACKUP_CODE_COUNT=10
TWO_FACTOR_TOTP_ISSUER=EWU Media
TWO_FACTOR_TOTP_WINDOW=1

# CORS / Frontend (required — must be HTTPS in production)
CORS_ORIGIN=http://localhost:4200
FRONTEND_URL=http://localhost:4200
ALLOWED_FRONTEND_URLS=http://localhost:4200

# AWS (shared)
AWS_REGION=us-east-1

# AWS S3
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_PRESIGNED_EXPIRY=3600
AWS_S3_PROFILE_IMAGE_PRESIGNED_EXPIRY=604800

# AWS SES
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=

# AWS SQS
AWS_SQS_ACCESS_KEY_ID=
AWS_SQS_SECRET_ACCESS_KEY=

# Redis (cache + queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Queue (SQS)
SQS_EMAIL_CLASSIFY_URL=

# Queue (BullMQ)
BULLMQ_DEFAULT_ATTEMPTS=3
BULLMQ_BACKOFF_TYPE=exponential
BULLMQ_BACKOFF_DELAY_MS=1000
BULLMQ_REMOVE_ON_COMPLETE=100
BULLMQ_REMOVE_ON_FAIL=500

# Notifications
NOTIFICATION_TTL_DAYS=90

# AI — AWS Bedrock (credentials optional — omit to use default AWS credential chain)
BEDROCK_ACCESS_KEY_ID=
BEDROCK_SECRET_ACCESS_KEY=
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_FALLBACK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBEDDING_MODEL_ID=cohere.embed-english-v4

# AI — Firecrawl (self-hosted via docker compose)
FIRECRAWL_API_URL=http://localhost:3002
FIRECRAWL_API_KEY=
FIRECRAWL_TIMEOUT_MS=30000

# AI — Chat
AI_SESSION_TTL_DAYS=30
AI_MAX_FILES_PER_MESSAGE=5
AI_MAX_UPLOAD_SIZE_MB=50

# Email Sync
EMAIL_SYNC_INTERVAL_MS=60000
EMAIL_SYNC_BATCH_SIZE=50

# Email Classifier
EMAIL_CLASSIFIER_CONCURRENCY=5

# Queue Worker
QUEUE_WORKER_HEALTH_PORT=3003

# Outbound Email (SES) — verified-identity allowlist + retry policy
AWS_SES_OUTBOUND_FROM_ALLOWLIST=record@staging.example.com,foia@staging.example.com
AWS_SES_CONFIGURATION_SET=
EMAIL_SEND_MAX_ATTEMPTS=3
EMAIL_SEND_BACKOFF_TYPE=exponential
EMAIL_SEND_BACKOFF_DELAY_MS=30000

# Share-link card icon — fetched ONCE per environment on the first share-link
# send, then copied to emails/system-assets/share-link-icon.png in our S3 and
# served via CID for every subsequent email. Point at an icon hosted on owned
# infrastructure (S3 / CloudFront). If unset, the card renders without an icon.
APP_PUBLIC_BASE_URL=https://api.staging.example.com
EMAIL_SHARE_LINK_ICON_URL=https://e7.pngegg.com/pngimages/358/453/png-clipart-computer-icons-hyperlink-symbol-miscellaneous-text-thumbnail.png

# Health Checks
HEALTH_HEAP_THRESHOLD_MB=512
HEALTH_RSS_THRESHOLD_MB=1024
HEALTH_DISK_THRESHOLD_PERCENT=0.95
HEALTH_DB_TIMEOUT_MS=1000

# Rate Limiting (per tier — limit = max requests, ttl = window in ms)
RATE_LIMIT_GLOBAL_LIMIT=250
RATE_LIMIT_GLOBAL_TTL_MS=60000
RATE_LIMIT_AUTH_LIMIT=10
RATE_LIMIT_AUTH_TTL_MS=900000
RATE_LIMIT_OTP_LIMIT=1
RATE_LIMIT_OTP_TTL_MS=60000
RATE_LIMIT_UPLOAD_LIMIT=30
RATE_LIMIT_UPLOAD_TTL_MS=3600000
RATE_LIMIT_PUBLIC_LIMIT=60
RATE_LIMIT_PUBLIC_TTL_MS=60000
RATE_LIMIT_REGISTRATION_LIMIT=5
RATE_LIMIT_REGISTRATION_TTL_MS=3600000

# reCAPTCHA v3
RECAPTCHA_SECRET_KEY=

# Swagger Basic Auth
SWAGGER_USER=admin
SWAGGER_PASSWORD=changeme

# WebSocket / Realtime
WS_PORT=3001

# Okta SSO (OIDC)
OKTA_DOMAIN=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_REDIRECT_URI=
OKTA_POST_LOGOUT_REDIRECT_URI=
OKTA_STATE_SECRET=
OKTA_WEBHOOK_SECRET=

# Cookie domain (required in production/staging, e.g. .ewumediastar.com)
COOKIE_DOMAIN=
