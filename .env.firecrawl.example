# =============================================================================
# Firecrawl Self-Hosted Configuration
# =============================================================================
# Copy this file to .env.firecrawl and update values for your environment.
# Usage: docker compose -f docker-compose.firecrawl.yml --env-file .env.firecrawl up -d
# =============================================================================

# --- Core ---
PORT=3002
INTERNAL_PORT=3002
HOST=0.0.0.0
LOGGING_LEVEL=info

# --- Redis ---
REDIS_URL=redis://firecrawl-redis:6379
REDIS_RATE_LIMIT_URL=redis://firecrawl-redis:6379

# --- Playwright ---
PLAYWRIGHT_MICROSERVICE_URL=http://firecrawl-playwright:3000

# --- Database (NUQ job queue) ---
# Firecrawl's DB auth requires Supabase (not just Postgres).
# For self-hosted without Supabase, disable auth and protect via network isolation.
USE_DB_AUTHENTICATION=false
# IMPORTANT: POSTGRES_DB must be 'postgres' — nuq-postgres image has pg_cron hardcoded to this DB name
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=firecrawl-postgres
POSTGRES_PORT=5432

# --- Performance Tuning ---
NUM_WORKERS_PER_QUEUE=8
CRAWL_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_JOBS=5
BROWSER_POOL_SIZE=5

# --- Admin ---
# Bull queue dashboard: http://localhost:3002/admin/<BULL_AUTH_KEY>/queues
# IMPORTANT: Set a strong key for production!
BULL_AUTH_KEY=changeme

# --- Test API Key (dev only) ---
# Used when USE_DB_AUTHENTICATION=false as the API key for all requests
TEST_API_KEY=fc-dev-test-key

# --- Optional: Block media in Playwright (saves bandwidth) ---
# BLOCK_MEDIA=true


# RabbitMQ
RABBITMQ_URL=amqp://changeme@rabbitmq:5672
NUQ_RABBITMQ_URL=amqp://changeme@rabbitmq:5672

# --- CloudWatch Logs ---
# Logs for firecrawl-api and firecrawl-playwright are shipped to CloudWatch.
# The EC2 instance IAM role must have the CloudWatchLogsFullAccess policy (or equivalent).
AWS_REGION=us-east-1
AWS_LOG_GROUP=/firecrawl/staging
